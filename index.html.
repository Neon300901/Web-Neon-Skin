<div class="total-box">

<h2>Total Harga: Rp <span id="total">0</span></h2>

<div class="qris">
<h3>Pembayaran QRIS</h3>
<img src="QRIS.png">
<p>Setelah transfer kirim bukti pembayaran.</p>
</div>

<button onclick="orderWA()">Order via WhatsApp</button>

</div>

</div>

<script>

const checkbox = document.querySelectorAll("input[type=checkbox]");
const totalText = document.getElementById("total");

checkbox.forEach(box=>{
box.addEventListener("change", hitungTotal);
});

function hitungTotal(){

let total = 0;

checkbox.forEach(box=>{
if(box.checked){
total += parseInt(box.dataset.price);
}
});

totalText.innerText = total.toLocaleString("id-ID");

}

function orderWA(){

let username = document.getElementById("username").value;

let items = [];

checkbox.forEach(box=>{
if(box.checked){
items.push(box.value);
}
});

let total = totalText.innerText;

let pesan =
`ORDER NEON STORE

Username : ${username}

Item :
${items.join("\n")}

Total : Rp ${total}

Saya sudah melakukan pembayaran via QRIS.
Berikut bukti transfer saya.`

let url = "https://wa.me/6285804197934?text=" + encodeURIComponent(pesan);

window.open(url,'_blank');

}

</script>

